{
  "name": "markdown42",
  "displayName": "Markdown42 — Live Markdown Editor",
  "description": "Typora-style inline preview. GitHub-accurate rendering. Smart outline. Zero split panes.",
  "version": "0.1.0",
  "publisher": "markdown42",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/markdown42/markdown42-vscode"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "preview",
    "wysiwyg",
    "typora",
    "obsidian",
    "github",
    "docs",
    "readme"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdown42.editor",
        "displayName": "Markdown42 Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "markdown42Outline",
          "name": "Document Outline",
          "when": "markdown42Active"
        }
      ]
    },
    "commands": [
      {
        "command": "markdown42.toggleSource",
        "title": "Markdown42: Toggle Source View",
        "icon": "$(code)"
      },
      {
        "command": "markdown42.openInMarkdown42",
        "title": "Open in Markdown42"
      },
      {
        "command": "markdown42.refreshOutline",
        "title": "Refresh Outline"
      },
      {
        "command": "markdown42.save",
        "title": "Markdown42: Save",
        "icon": "$(save)"
      }
    ],
    "keybindings": [
      {
        "command": "markdown42.toggleSource",
        "key": "ctrl+`",
        "mac": "cmd+`",
        "when": "markdown42EditorActive"
      },
      {
        "command": "markdown42.save",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "markdown42EditorActive"
      }
    ],
    "configuration": {
      "title": "Markdown42",
      "properties": {
        "markdown42.defaultMode": {
          "type": "string",
          "enum": [
            "preview",
            "source"
          ],
          "default": "preview",
          "description": "Default editor mode when opening a markdown file"
        },
        "markdown42.fontSize": {
          "type": "number",
          "default": 16,
          "minimum": 10,
          "maximum": 32,
          "description": "Base font size in px for prose content"
        },
        "markdown42.lineWidth": {
          "type": "number",
          "default": 860,
          "minimum": 400,
          "maximum": 1800,
          "description": "Maximum content width in px"
        },
        "markdown42.syncScrollOutline": {
          "type": "boolean",
          "default": true,
          "description": "Highlight current heading in outline as you scroll"
        },
        "markdown42.enableTelemetry": {
          "type": "boolean",
          "default": false,
          "description": "Send anonymous usage data to improve Markdown42 (opt-in)"
        },
        "markdown42.renderDelay": {
          "type": "number",
          "default": 150,
          "minimum": 50,
          "maximum": 1000,
          "description": "Debounce delay in ms before re-rendering after a keystroke"
        },
        "markdown42.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save to disk after every edit (Typora-style). When false, use Ctrl+S or the save button."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./test/tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "build:webview": "node esbuild.config.js",
    "watch:webview": "node esbuild.config.js --watch",
    "test": "npm run compile:test && node ./out/test/runTests.js",
    "test:unit": "npm run compile:test && mocha --ui tdd \"out-test/test/suite/**/*.test.js\" --timeout 10000",
    "test:e2e": "playwright test test/e2e/",
    "test:coverage": "nyc npm run test:unit",
    "lint": "eslint src/ test/ --ext .ts",
    "lint:fix": "eslint src/ test/ --ext .ts --fix",
    "audit:check": "npm audit --audit-level=moderate",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish",
    "clean": "node -e \"const fs=require('fs');['out','coverage'].forEach(d=>{try{fs.rmSync(d,{recursive:true})}catch{}})\" && echo Cleaned"
  },
  "dependencies": {
    "markdown-it": "14.1.1",
    "markdown-it-emoji": "3.0.0",
    "markdown-it-task-lists": "2.1.1"
  },
  "devDependencies": {
    "@types/chai": "4.3.20",
    "@types/glob": "8.1.0",
    "@types/jsdom": "^28.0.0",
    "@types/markdown-it": "14.1.2",
    "@types/mocha": "10.0.10",
    "@types/node": "20.17.19",
    "@types/sinon": "17.0.3",
    "@types/vscode": "1.85.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vscode/test-electron": "2.4.1",
    "chai": "4.5.0",
    "esbuild": "0.27.3",
    "eslint": "8.57.1",
    "jsdom": "^28.1.0",
    "mocha": "10.8.2",
    "nyc": "15.1.0",
    "playwright": "1.58.2",
    "sinon": "21.0.2",
    "typescript": "5.7.3"
  },
  "overrides": {
    "serialize-javascript": "^6.0.2"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "out/test/**",
      "test/**"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "all": true,
    "check-coverage": true,
    "lines": 80,
    "functions": 80,
    "branches": 75
  }
}
