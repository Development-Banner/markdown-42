# Files excluded from the .vsix package
# Keep the package lean (<2MB)

# Source TypeScript (compiled JS is in out/)
src/**
media/editor.ts
media/renderer.ts
media/inlineEditor.ts

# Tests
test/**
out/test/**

# Config and tooling
.github/**
.vscode/**
.claude/**
.eslintrc.json
tsconfig.json
test/tsconfig.test.json
esbuild.config.js
.npmrc

# Dev artifacts
node_modules/**
coverage/**
.nyc_output/**
out-test/**
.worktrees/**
.rainbow/**
temp-*/**
temp-*.js
*.vsix
temp-tabbar-only.js
**/*.map
package-lock.json
AGENTS.md
CLAUDE.md
LEARNINGS.md
HISTORY.md

# README-only assets (served from GitHub raw URL, not packaged)
media/*.gif

# Documentation and misc
docs/**
*.md
!README.md
!CHANGELOG.md
PRD_markdown42.md.md

# Build inputs (not needed in package)
**/*.ts
!out/**/*.js
